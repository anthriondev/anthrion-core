    "format": "prettier --write src",
    "test": "tsx --test src/*.test.ts"
  },
  "devDependencies": {
    "@anthrion/config": "workspace:*",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  }
}
