# Node
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5436/anthrion

# Redis
REDIS_URL=redis://localhost:6380

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=anthrion

# Auth — Privy
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=

# LLM — OpenRouter (gateway; model is read from env, not hardcoded)
OPENROUTER_API_KEY=
# REQUIRED. Set both to the OpenRouter slug you want each tier to use. There is no
# default — the app fails to start at env-load if either is unset, so the model
# choice is always an explicit operator decision (see packages/shared/src/env.ts).
# Use paid slugs (not :free) to avoid free-tier rate limits during real scans.
# Light tier = volume work (Layer 1 probes, evaluator); heavy tier = adaptive
# attacker (Layer 2). It is fine to set the same slug for both initially; promote
# heavy to a stronger model via env later.
LLM_MODEL_LIGHT=<your-openrouter-model-slug>
LLM_MODEL_HEAVY=<your-openrouter-model-slug>
# Token budget cap per scan (input+output). Conservative default for the test phase.
LLM_TOKEN_BUDGET_PER_SCAN=20000

# Payment
PAYMENT_USDC_BASE_ADDRESS=
PAYMENT_USDC_SOLANA_ADDRESS=
# Per-scan price in USDC ATOMIC units (6 decimals): "10000" = 0.01 USDC. "0" = FREE_PRICING
# (Phase 1 default: all scans free, no on-chain tx). Global for Phase 1.
SCAN_PRICE_USDC_ATOMIC=0
# Treasury address that receives USDC for paid scans (x402 payTo). Public address, not a
# secret. Leave empty in Phase 1 (price 0). No private keys belong in env.
PAYMENT_PAYTO_BASE_ADDRESS=

# Scan sandbox (worker, T3.2). All optional — these are the proposed conservative
# Phase-1 defaults. Limits are LOOSE safety nets (a normal scan, including a web
# scan driving Chromium, never hits them), not tight knives that would corrupt scan
# accuracy. Raise them on a larger host as needed.
# Image built by scripts/build-sandbox-image.sh:
SANDBOX_IMAGE=anthrion-scan-runtime:latest
# Dedicated bridge network (auto-created) isolating scan containers from host services:
SANDBOX_NETWORK=anthrion-scan-net
# Memory cap (MB). Chromium single-page scan peaks well under 1 GB; 1.5 GB is headroom,
# and caps a runaway at <20% of an 8 GB host. Swap is disabled so OOM is clean.
SANDBOX_MEMORY_MB=1536
# CPU cap (cores). 1.0 of 4 = good speed, capped at 25% of host CPU.
SANDBOX_CPUS=1
# Process cap (fork-bomb defence). Chromium needs a few dozen; 512 is headroom.
SANDBOX_PIDS_LIMIT=512
# Overall container wall-clock lifetime (ms). Set ABOVE the engine's own per-operation
# timeouts so the engine times out and reports honestly first; this only catches a
# wedged engine.
SANDBOX_LIFETIME_MS=300000
# /dev/shm size (MB) for Chromium stability.
SANDBOX_SHM_SIZE_MB=256

# Web client — API base URL (T-B1.4). Dev = local api; prod = https://api.anthrion.xyz
NEXT_PUBLIC_API_URL=http://localhost:3001

# API CORS allow-list (T-B1.4). Exact origin, never a wildcard. Set per environment:
#   - local dev:  http://localhost:3000
#   - production: https://app.anthrion.xyz
API_CORS_ORIGIN=http://localhost:3000

# Rate limiting (T-B1.1). Tuned per environment.
RATE_LIMIT_DEFAULT_PER_MINUTE=60
RATE_LIMIT_SCANS_PER_HOUR=10
# NEVER true in production — the limiter is the only thing keeping the free-pricing
# scan endpoint from draining the OpenRouter balance. Tests force it on locally.
RATE_LIMIT_DISABLED=false
