{
  "name": "@anthrion/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3000 --hostname 127.0.0.1",
    "start": "next start --port 3000 --hostname 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "test": "TSX_TSCONFIG_PATH=./tsconfig.test.json tsx --test src/lib/*.test.ts src/app/*.test.tsx src/app/scans/_components/*.test.ts src/app/scans/_components/*.test.tsx"
  },
  "devDependencies": {
    "@anthrion/config": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "global-jsdom": "^29.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@anthrion/shared": "workspace:*",
    "@anthrion/ui": "workspace:*",
    "@privy-io/react-auth": "^3.27.1",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.4.3"
  }
}
