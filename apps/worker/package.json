{
  "name": "@anthrion/worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "DOTENV_CONFIG_PATH=../../.env tsx --import dotenv/config src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "test": "tsx --test --test-concurrency=1 src/*.test.ts src/report/*.test.ts src/sandbox/*.test.ts"
  },
  "devDependencies": {
    "@anthrion/config": "workspace:*",
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@anthrion/db": "workspace:*",
    "@anthrion/sandbox-runtime": "workspace:*",
    "@anthrion/scan-engine": "workspace:*",
    "@anthrion/shared": "workspace:*",
    "@anthrion/ui": "workspace:^",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "bullmq": "^5.77.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "minio": "^8.0.7",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  }
}
